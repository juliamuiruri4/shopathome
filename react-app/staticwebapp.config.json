{
  "trailingSlash": "auto",
  "routes": [
    {
      "route": "/api/*",
      "methods": [
        "GET"
      ],
      "allowedRoles": [
        "authenticated"
      ]
    },
    {
      "route": "/api/products/*",
      "methods": [
        "get",
        "post",
        "put",
        "delete"
      ],
      "allowedRoles": [
        "authenticated"
      ]
    }
  ]
}
